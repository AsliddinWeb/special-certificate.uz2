#: templates/core/certification-body-pro.html:99
#: templates/core/testing-laboratory.html:79
msgid "Akkreditatsiyadan o'tgan"
msgstr "Прошёл аккредитацию"

#: templates/core/certification-body-pro.html:113
msgid "Akkreditatsiya"
msgstr "Аккредитация"

#: templates/core/certification-body-pro.html:114
msgid "Tasdiqlangan"
msgstr "Подтверждён"

#: templates/core/certification-body-pro.html:130
msgid "Sertifikatlash qoidalari"
msgstr "Правила сертификации"

#: templates/core/certification-body-pro.html:133
msgid "Sertifikatlash tartib-taomillari"
msgstr "Процедуры сертификации"

#: templates/core/certification-body-pro.html:136
msgid ""
"Mahsulotlarni sertifikatlash qoidalari \"PSP OS 03:2025, Boshqaruv tizimi "
"hujjati\" bilan tartibga solinadi"
msgstr ""
"Правила сертификации продукции регулируются документом «ПСП ОС 03:2025, "
"Документ системы менеджмента»"

#: templates/core/certification-body-pro.html:144
msgid "Huquqiy asos"
msgstr "Правовая основа"

#: templates/core/certification-body-pro.html:146
msgid ""
"Mahsulotlarni sertifikatlash qoidalari O'zbekiston Respublikasi Vazirlar "
"Mahkamasining quyidagi qarorlari asosida ishlab chiqilgan:"
msgstr ""
"Правила сертификации продукции разработаны на основании следующих "
"постановлений Кабинета Министров Республики Узбекистан:"

#: templates/core/certification-body-pro.html:155
msgid ""
"2025-yil 14-avgustdagi <strong class=\"text-dark dark:text-white\">502-son</"
"strong> qarori"
msgstr ""
"Постановление <strong class=\"text-dark dark:text-white\">№502</strong> от "
"14 августа 2025 года"

#: templates/core/certification-body-pro.html:163
msgid ""
"2004-yil 6-iyuldagi <strong class=\"text-dark dark:text-white\">318-son</"
"strong> qarori"
msgstr ""
"Постановление <strong class=\"text-dark dark:text-white\">№318</strong> от 6 "
"июля 2004 года"

#: templates/core/certification-body-pro.html:169
msgid "Tartibga solingan jarayonlar"
msgstr "Регулируемые процессы"

#: templates/core/certification-body-pro.html:177
msgid "Baholash tartib-taomillari"
msgstr "Процедуры оценки"

#: templates/core/certification-body-pro.html:185
msgid "Muvofiqlik sertifikatini berish va tasdiqlash"
msgstr "Выдача и подтверждение сертификата соответствия"

#: templates/core/certification-body-pro.html:193
msgid "Amal qilish sohasini kengaytirish yoki qisqartirish"
msgstr "Расширение или сокращение области действия"

#: templates/core/certification-body-pro.html:201
msgid "Sertifikatni to'xtatib turish va bekor qilish"
msgstr "Приостановление и аннулирование сертификата"

#: templates/core/certification-body-pro.html:209
msgid "Sertifikatlashni rad etish tartibi"
msgstr "Порядок отказа в сертификации"

#: templates/core/certification-body-pro.html:225
msgid "To'lov tartibi"
msgstr "Порядок оплаты"

#: templates/core/certification-body-pro.html:228
msgid "Xizmatlar uchun to'lov"
msgstr "Оплата за услуги"

#: templates/core/certification-body-pro.html:231
msgid ""
"Sertifikatlashtirish organi barcha manfaatdor tomonlarga xizmatlaridan teng "
"foydalanish imkoniyatini ta'minlaydi"
msgstr ""
"Орган по сертификации обеспечивает всем заинтересованным сторонам равный "
"доступ к своим услугам"

#: templates/core/certification-body-pro.html:244
msgid "Teng huquqli xizmat"
msgstr "Равное обслуживание"

#: templates/core/certification-body-pro.html:246
msgid ""
"OS barcha manfaatdor tomonlarga — buyurtmachi tashkilotning hajmidan, uning "
"har qanday uyushma yoki guruhlarga a'zoligidan, shuningdek ilgari berilgan "
"sertifikatlar sonidan qat'i nazar — sertifikatlashtirish organi "
"xizmatlaridan teng foydalanish imkoniyatini ta'minlaydi."
msgstr ""
"ОС обеспечивает всем заинтересованным сторонам — независимо от размера "
"организации заказчика, его членства в каких-либо ассоциациях или группах, а "
"также количества ранее выданных сертификатов — равный доступ к услугам "
"органа по сертификации."

#: templates/core/certification-body-pro.html:252
msgid "Belgilangan (fiksirlangan) tarif bo'yicha to'lov"
msgstr "Оплата по установленному (фиксированному) тарифу"

#: templates/core/certification-body-pro.html:258
msgid "To'lanadigan xizmatlar"
msgstr "Платные услуги"

#: templates/core/certification-body-pro.html:264
msgid "Arizani ko'rib chiqish va ariza bo'yicha qaror qabul qilish"
msgstr "Рассмотрение заявки и принятие решения по заявке"

#: templates/core/certification-body-pro.html:270
msgid "Sertifikatlash ob'yektlarini aniqlash va tanlab olish"
msgstr "Идентификация и отбор объектов сертификации"

#: templates/core/certification-body-pro.html:276
msgid "Sertifikatlash ob'yektlarini sinov laboratoriyasiga yetkazib berish"
msgstr "Доставка объектов сертификации в испытательную лабораторию"

#: templates/core/certification-body-pro.html:282
msgid ""
"Mahsulotni sertifikatlash bilan bog'liq barcha yozuvlarni rasmiylashtirish"
msgstr "Оформление всех записей, связанных с сертификацией продукции"

#: templates/core/certification-body-pro.html:288
#: templates/core/certification-body.html:201
msgid "Muvofiqlik sertifikatini berish"
msgstr "Выдача сертификата соответствия"

#: templates/core/certification-body-pro.html:294
msgid ""
"Muvofiqlik belgisi (markasi)dan foydalanish uchun bir martalik to'lovlar "
"(PKM 348-son, 6-band)"
msgstr ""
"Разовые платежи за использование знака (марки) соответствия (ПКМ №348, пункт "
"6)"

#: templates/core/certification-body-pro.html:300
msgid ""
"<strong class=\"text-dark dark:text-white\">Eslatma:</strong> Buyurtmachi "
"so'rovi asosida OS mahsulotni sertifikatlash xizmatlari uchun to'lov "
"bo'yicha asoslangan tushuntirishlar bilan birga kalkulyatsiyani taqdim "
"etishga majburdir."
msgstr ""
"<strong class=\"text-dark dark:text-white\">Примечание:</strong> По запросу "
"заказчика ОС обязан предоставить калькуляцию по оплате услуг сертификации "
"продукции с обоснованными пояснениями."

#: templates/core/certification-body-pro.html:315
msgid "Huquq va majburiyatlar"
msgstr "Права и обязанности"

#: templates/core/certification-body-pro.html:318 templates/core/home.html:363
msgid "Buyurtmachi huquq va majburiyatlari"
msgstr "Права и обязанности заказчика"

#: templates/core/certification-body-pro.html:321
msgid "OS buyurtmachilar bilan yuridik kuchga ega bo'lgan kelishuv tuzadi"
msgstr "ОС заключает с заказчиками юридически обязательное соглашение"

#: templates/core/certification-body-pro.html:335
msgid "Kelishuv hujjati"
msgstr "Документ соглашения"

#: templates/core/certification-body-pro.html:337
msgid ""
"\"Muvofiqlik sertifikatini qo'llash va muvofiqlik belgisidan foydalanish "
"huquqini berish to'g'risidagi kelishuv\" buyurtmachidan ariza kelib "
"tushganidan so'ng tuziladi."
msgstr ""
"«Соглашение о применении сертификата соответствия и предоставлении права "
"использования знака соответствия» заключается после поступления заявки от "
"заказчика."

#: templates/core/certification-body-pro.html:341
msgid ""
"<strong class=\"text-dark dark:text-white\">Ilova (RSM OS 01:F01)</strong> — "
"unda OS hamda buyurtmachining javobgarligi (\"TOMONLARNING JAVOBGARLIGI\" "
"bandi) belgilab qo'yiladi."
msgstr ""
"<strong class=\"text-dark dark:text-white\">Приложение (РСМ ОС 01:F01)</"
"strong> — в нём устанавливается ответственность ОС и заказчика (пункт "
"«ОТВЕТСТВЕННОСТЬ СТОРОН»)."

#: templates/core/certification-body-pro.html:348
